<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BambuMan.Shared.Models;assembly=BambuMan.Shared"
             xmlns:m="clr-namespace:BambuMan.Resources.Icons"
             xmlns:main="clr-namespace:BambuMan.UI.Main"
             
             xmlns:md="clr-namespace:HorusStudio.Maui.MaterialDesignControls;assembly=HorusStudio.Maui.MaterialDesignControls"
             xmlns:converters="clr-namespace:BambuMan.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:shared="clr-namespace:BambuMan"
             xmlns:controls="clr-namespace:BambuMan.UI.Controls"

             x:Class="BambuMan.UI.Main.MainPage"
             Title="BambuMan Reader"
             x:DataType="main:MainPageViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="10">

            <Border Stroke="{AppThemeBinding Light={StaticResource VersionBannerStroke}, Dark={StaticResource VersionBannerStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource VersionBannerBackground}, Dark={StaticResource VersionBannerBackgroundDark}}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Margin="0,0,0,5" Padding="5" IsVisible="{Binding NewVersionAvailable}">
                <VerticalStackLayout>
                    <Label Text="{Binding NewVersionText}" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource VersionBannerText}, Dark={StaticResource VersionBannerTextDark}}" FontSize="14"></Label>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*" Margin="0,0,0,5">
                <Border Grid.Column="0" StrokeThickness="1" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}" HeightRequest="26" >
                    <HorizontalStackLayout>
                        <!-- BackgroundColor="{Binding SettingsOk, Converter={StaticResource BoolToColorConverter}}" -->
                        <Image HeightRequest="10" Margin="10,0,0,0">
                            <Image.Source>
                                <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Circle}" Color="{Binding SettingsOk, Converter={StaticResource BoolToColorConverter}}" />
                            </Image.Source>
                        </Image>

                        <Label Margin="0" Padding="8,4,8,4" FontSize="13" HeightRequest="26" HorizontalTextAlignment="Center" Text="SETTINGS"></Label>
                    </HorizontalStackLayout>
                </Border>
                <Border Grid.Column="1" StrokeThickness="1" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}" HeightRequest="26" >
                    <HorizontalStackLayout>
                        <!-- BackgroundColor="{Binding SpoolmanOk, Converter={StaticResource BoolToColorConverter}}" -->
                        <Image HeightRequest="10" Margin="10,0,0,0">
                            <Image.Source>
                                <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Circle}" Color="{Binding SpoolmanOk, Converter={StaticResource BoolToColorConverter}}" />
                            </Image.Source>
                        </Image>

                        <Label Margin="0" Padding="8,4,8,4" FontSize="13" HeightRequest="26" HorizontalTextAlignment="Center" Text="{Binding BackendLabel}"></Label>
                    </HorizontalStackLayout>
                </Border>
                <Border Grid.Column="2" StrokeThickness="1" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}" HeightRequest="26" >
                    <HorizontalStackLayout>
                        <!-- BackgroundColor="{Binding NfcIsEnabled, Converter={StaticResource BoolToColorConverter}}" -->
                        <Image HeightRequest="10" Margin="10,0,0,0">
                            <Image.Source>
                                <FontImageSource FontFamily="MaterialSharp" Glyph="{x:Static m:MaterialSharp.Circle}" Color="{Binding NfcIsEnabled, Converter={StaticResource BoolToColorConverter}}" />
                            </Image.Source>
                        </Image>
                        <Label Margin="0" Padding="8,4,8,4" FontSize="13" HeightRequest="26" HorizontalTextAlignment="Center" Text="{Binding NfcText}"></Label>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <VerticalStackLayout x:Name="ErrorMessages" Margin="0,0,0,5" IsVisible="{Binding ErrorMessage, Converter={StaticResource NoNullToBoolConverter}}">
                <Border StrokeThickness="1" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource ErrorBannerStroke}, Dark={StaticResource ErrorBannerStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource ErrorBannerBackground}, Dark={StaticResource ErrorBannerBackgroundDark}}">
                    <Label Margin="0" Padding="8,4,8,4" TextColor="{AppThemeBinding Light={StaticResource ErrorBannerText}, Dark={StaticResource ErrorBannerTextDark}}" FontSize="12">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span FontAttributes="Bold" Text="Error: "></Span>
                                <Span Text="{Binding ErrorMessage}"></Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="SuccessMessages" Margin="0,0,0,5" IsVisible="{Binding SuccessMessage, Converter={StaticResource NoNullToBoolConverter}}">
                <Border StrokeThickness="1" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource SuccessBannerStroke}, Dark={StaticResource SuccessBannerStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource SuccessBannerBackground}, Dark={StaticResource SuccessBannerBackgroundDark}}" >
                    <Label Margin="0" Padding="8,4,8,4" TextColor="{AppThemeBinding Light={StaticResource SuccessBannerText}, Dark={StaticResource SuccessBannerTextDark}}" FontSize="14">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span FontAttributes="Bold" Text="Success: "></Span>
                                <Span Text="{Binding SuccessMessage}"></Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout x:Name="InfoMessages" Margin="0,0,0,5" IsVisible="{Binding InfoMessage, Converter={StaticResource NoNullToBoolConverter}}">
                <Border StrokeThickness="1" StrokeShape="RoundRectangle 12" Stroke="{AppThemeBinding Light={StaticResource InfoBannerStroke}, Dark={StaticResource InfoBannerStrokeDark}}" BackgroundColor="{AppThemeBinding Light={StaticResource InfoBannerBackground}, Dark={StaticResource InfoBannerBackgroundDark}}" >
                    <Label Margin="0" Padding="8,4,8,4" TextColor="{AppThemeBinding Light={StaticResource InfoBannerText}, Dark={StaticResource InfoBannerTextDark}}" FontSize="14">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span FontAttributes="Bold" Text="Info: "></Span>
                                <Span Text="{Binding InfoMessage}"></Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>
            </VerticalStackLayout>

            <StackLayout IsVisible="{Binding HasInventoryItems}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Text="Inventory:" FontAttributes="Bold" Grid.Column="0" VerticalOptions="Center"></Label>
                    <md:MaterialButton Grid.Column="1" Type="Text" Text="Clear inventory" Clicked="ClearInventory_OnClicked" />
                </Grid>
                <StackLayout BindableLayout.ItemsSource="{Binding Inventory, Mode=OneWay}" Orientation="Horizontal">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="shared:InventoryModel">
                            <!-- M3 outlined chip: filament color shown as a dot so the label stays readable on any color -->
                            <Border StrokeThickness="1" StrokeShape="RoundRectangle 8" Margin="2" Padding="8,4"
                                    Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                                    BackgroundColor="Transparent">
                                <HorizontalStackLayout Spacing="6">
                                    <Ellipse Fill="{Binding Color}" HeightRequest="12" WidthRequest="12" VerticalOptions="Center"
                                             Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}" StrokeThickness="1" />
                                    <Label VerticalOptions="Center" FontSize="13">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding Material}" />
                                                <Span Text=" × " />
                                                <Span Text="{Binding Quantity}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </StackLayout>

            <Border HeightRequest="2" BackgroundColor="{AppThemeBinding Light={StaticResource Separator}, Dark={StaticResource SeparatorDark}}" Margin="0,5,0,5" IsVisible="{Binding HasInventoryItems}"></Border>

            <VerticalStackLayout HorizontalOptions="Center" Margin="0,20,0,20" IsVisible="{Binding SpoolmanConnecting}">
                <ActivityIndicator IsRunning="true" HeightRequest="110" />
                <Label Text="Connecting, please wait ..." Margin="0,10,0,0" FontAttributes="Bold"></Label>
            </VerticalStackLayout>

            <Border Stroke="{AppThemeBinding Light={StaticResource SpoolCardStroke}, Dark={StaticResource SpoolCardStrokeDark}}" StrokeThickness="1" StrokeShape="RoundRectangle 12" Background="{AppThemeBinding Light={StaticResource SpoolCardBackground}, Dark={StaticResource SpoolCardBackgroundDark}}" Margin="0,0,0,5" Padding="5" IsVisible="{Binding ShowSpoolEdit}">
                <VerticalStackLayout>
                    <Label Text="Spool info:" FontAttributes="Bold"></Label>

                    <!-- FlexLayout so hidden fields (Bambuddy: Buy date / Lot nr) reflow without leaving gaps -->
                    <FlexLayout Wrap="Wrap" JustifyContent="SpaceBetween" AlignItems="Start" Margin="5">

                        <md:MaterialTextField x:Name="TfSpoolWeight" FlexLayout.Basis="49%" Label="Weight (g)" Type="Outlined" Keyboard="Numeric" Text="{Binding SpoolWeight, Mode=TwoWay}" LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Weight}}" />

                        <md:MaterialTextField x:Name="TfSpoolEmptyWeight" FlexLayout.Basis="49%" Label="Empty weight (g)" Type="Outlined" Keyboard="Numeric" Text="{Binding SpoolEmptyWeight, Mode=TwoWay}" LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Settings_backup_restore}}" />

                        <md:MaterialTextField x:Name="TfSpoolPrice" FlexLayout.Basis="49%" Label="Price" Type="Outlined" Keyboard="Numeric" Text="{Binding SpoolPrice, Mode=TwoWay}" LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Sell}}" />

                        <md:MaterialDatePicker x:Name="TfSpoolBuyDate" FlexLayout.Basis="49%" IsVisible="{Binding ShowBuyDate}" Label="Buy date" Type="Outlined" Date="{Binding SpoolBuyDate, Mode=TwoWay}" Placeholder="yyyy-MM-dd" Format="yyyy-MM-dd" LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Calendar_month}}" />

                        <md:MaterialTextField x:Name="TfSpoolLotNr" FlexLayout.Basis="49%" IsVisible="{Binding ShowLotNr}" Label="Lot nr" Type="Outlined" Text="{Binding SpoolLotNr, Mode=TwoWay}" LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Tag}}" />

                        <controls:MaterialAutoCompleteField x:Name="TfSpoolLocation" FlexLayout.Basis="49%" Label="Location" Text="{Binding SpoolLocation, Mode=TwoWay}" ItemsSource="{Binding ExistingLocations}" LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Map}}" />

                        <md:MaterialButton FlexLayout.Basis="49%" Margin="0,8,0,0" Type="Outlined" Text="Cancel" Clicked="CloseButton_OnClicked" />

                        <md:MaterialButton FlexLayout.Basis="49%" Margin="0,8,0,0" Type="Filled" Text="Save changes" Clicked="SaveChanges_OnClicked" />

                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Margin="0,0,0,5" IsVisible="{Binding IsTest}">
                <md:MaterialButton Clicked="Button_OnClicked" Text="Test Tag" Type="Filled" />
            </VerticalStackLayout>

            <Border
                StrokeThickness="1"
                StrokeShape="RoundRectangle 12"
                Stroke="{AppThemeBinding Light={StaticResource OutlineVariant}, Dark={StaticResource OutlineVariantDark}}"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceContainer}, Dark={StaticResource SurfaceContainerDark}}"
                Padding="12,4"
                Margin="0,5,0,5">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Override location on read" VerticalTextAlignment="Center" FontSize="14" />
                    <Switch Grid.Column="1" IsToggled="{Binding OverrideLocationOnRead, Mode=TwoWay}" VerticalOptions="Center" />
                </Grid>
            </Border>

            <Border HeightRequest="2" BackgroundColor="{AppThemeBinding Light={StaticResource Separator}, Dark={StaticResource SeparatorDark}}" Margin="0,5,0,5" IsVisible="{Binding ShowLogsOnMainPage}"></Border>

            <StackLayout IsVisible="{Binding ShowLogsOnMainPage}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Label Text="Logs:" FontAttributes="Bold" Grid.Column="0" VerticalOptions="Center"></Label>
                    <md:MaterialButton Grid.Column="1" Type="Text" Text="Clear logs" Clicked="ClearLogs_OnClicked" />
                    <md:MaterialButton Grid.Column="2" Type="Text" Text="Email logs" Clicked="EmailLogs_OnClicked" />
                </Grid>

                <StackLayout BindableLayout.ItemsSource="{Binding Logs, Mode=OneWay}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:LogModel">
                            <StackLayout>
                                <Label Text="{Binding Content}" TextColor="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"></Label>
                            </StackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </StackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
