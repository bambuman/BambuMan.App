<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:m="clr-namespace:BambuMan.Resources.Icons"
             xmlns:main="clr-namespace:BambuMan.UI.Settings"
             xmlns:controls="clr-namespace:BambuMan.UI.Controls"
             xmlns:md="clr-namespace:HorusStudio.Maui.MaterialDesignControls;assembly=HorusStudio.Maui.MaterialDesignControls"
             x:Class="BambuMan.UI.Settings.SettingsPage"
             x:DataType="main:SettingsPageViewModel"
             Title="BambuMan Settings">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="8">

            <md:MaterialSegmentedButton ItemsSource="{Binding BackendItems}" SelectedItem="{Binding SelectedBackendItem}" Type="Filled" HorizontalOptions="Fill" Margin="0,0,0,8" />

            <!-- Connection -->
            <Label Text="Connection" Style="{StaticResource SectionHeader}" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <md:MaterialTextField x:Name="TfServerUrl" Grid.Column="0" Label="Server URL" Type="Outlined" AlwaysShowLabel="True"
                                      Keyboard="Url" Placeholder="https://server:port"
                                      Text="{Binding ServerUrl, Mode=TwoWay}"
                                      LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Link}}" />
                <md:MaterialIconButton Grid.Column="1" VerticalOptions="Center" Type="Outlined"
                                       Clicked="ScanQr_OnClicked" CommandParameter="server_url"
                                       ImageSource="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Qr_code_scanner}}" />
            </Grid>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" IsVisible="{Binding IsBambuddy}">
                <md:MaterialTextField x:Name="TfBambuddyApiKey" Grid.Column="0" Label="Bambuddy API key" Type="Outlined" AlwaysShowLabel="True"
                                      Placeholder="bb_…"
                                      Text="{Binding BambuddyApiKey, Mode=TwoWay}"
                                      LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Key}}" />
                <md:MaterialIconButton Grid.Column="1" VerticalOptions="Center" Type="Outlined"
                                       Clicked="ScanQr_OnClicked" CommandParameter="bambuddy_key"
                                       ImageSource="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Qr_code_scanner}}" />
            </Grid>

            <md:MaterialButton Text="Test Spoolman URL" Type="Outlined" HorizontalOptions="Start" Margin="0,4,0,0"
                               IsVisible="{Binding IsSpoolman}" Clicked="TestSpoolmanUrl_OnClicked"
                               ImageSource="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Link}}" />
            <md:MaterialButton Text="Test Bambuddy URL" Type="Outlined" HorizontalOptions="Start" Margin="0,4,0,0"
                               IsVisible="{Binding IsBambuddy}" Clicked="TestBambuddyUrl_OnClicked"
                               ImageSource="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Link}}" />

            <!-- Data sharing -->
            <Label Text="Data sharing" Style="{StaticResource SectionHeader}" />

            <Grid ColumnDefinitions="*,Auto,Auto" MinimumHeightRequest="56">
                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Label Text="Participate in NFC data upload [beta]" Style="{StaticResource BodyLarge}" />
                    <Label Text="Help build the public Bambu RFID library." Style="{StaticResource BodyMedium}" Opacity="0.7" />
                </VerticalStackLayout>
                <md:MaterialIconButton Grid.Column="1" VerticalOptions="Center" Type="Standard" Clicked="InfoButton_OnClicked"
                                       IconTintColor="{AppThemeBinding Light={StaticResource Outline}, Dark={StaticResource OutlineDark}}"
                                       ImageSource="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Info}}" />
                <Switch Grid.Column="2" VerticalOptions="Center" IsToggled="{Binding FullTagScanAndUpload, Mode=TwoWay}" />
            </Grid>

            <!-- Behavior: tight M3 list rows (48dp), no extra spacing between rows -->
            <Label Text="Behavior" Style="{StaticResource SectionHeader}" />

            <VerticalStackLayout Spacing="0">
                <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="48">
                    <Label Grid.Column="0" Text="Import unknown filament" Style="{StaticResource BodyLarge}" VerticalOptions="Center" />
                    <Switch Grid.Column="1" VerticalOptions="Center" IsToggled="{Binding UnknownFilamentEnabled, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="48">
                    <Label Grid.Column="0" Text="Show logs on main page" Style="{StaticResource BodyLarge}" VerticalOptions="Center" />
                    <Switch Grid.Column="1" VerticalOptions="Center" IsToggled="{Binding ShowLogsOnMainPage, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="48">
                    <Label Grid.Column="0" Text="Show keyboard on spool read" Style="{StaticResource BodyLarge}" VerticalOptions="Center" />
                    <Switch Grid.Column="1" VerticalOptions="Center" IsToggled="{Binding ShowKeyboardOnSpoolRead, Mode=TwoWay}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" MinimumHeightRequest="48">
                    <Label Grid.Column="0" Text="Override location on read" Style="{StaticResource BodyLarge}" VerticalOptions="Center" />
                    <Switch Grid.Column="1" VerticalOptions="Center" IsToggled="{Binding OverrideLocationOnRead, Mode=TwoWay}" />
                </Grid>
            </VerticalStackLayout>

            <!-- Defaults applied on read -->
            <Label Text="Defaults applied on read" Style="{StaticResource SectionHeader}" />

            <md:MaterialDatePicker x:Name="TfBuyDate" IsVisible="{Binding IsSpoolman}" Label="Buy date" Type="Outlined" AlwaysShowLabel="True"
                                   Date="{Binding BuyDate, Mode=TwoWay}" Placeholder="yyyy-MM-dd" Format="yyyy-MM-dd"
                                   LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Calendar_month}}" />

            <md:MaterialTextField x:Name="TfPrice" Label="Price" Type="Outlined" AlwaysShowLabel="True" Keyboard="Numeric"
                                  Placeholder="0.00"
                                  Text="{Binding DefaultPrice, Mode=TwoWay}"
                                  LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Sell}}" />

            <md:MaterialTextField x:Name="TfLotNr" IsVisible="{Binding IsSpoolman}" Label="Lot nr" Type="Outlined" AlwaysShowLabel="True"
                                  Text="{Binding DefaultLotNr, Mode=TwoWay}"
                                  LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Tag}}" />

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <controls:MaterialAutoCompleteField x:Name="TfLocation" Grid.Column="0" Label="Location"
                                                    Text="{Binding DefaultLocation, Mode=TwoWay}"
                                                    ItemsSource="{Binding ExistingLocations}"
                                                    LeadingIcon="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Map}}" />
                <md:MaterialIconButton Grid.Column="1" VerticalOptions="Start" Margin="0,8,0,0" Type="Outlined"
                                       Clicked="RefreshLocations_OnClicked"
                                       ImageSource="{FontImageSource FontFamily=MaterialSharp, Glyph={x:Static m:MaterialSharp.Refresh}}" />
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
